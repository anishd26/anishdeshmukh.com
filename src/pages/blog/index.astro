---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="Writing" description="Writing by Anish Deshmukh.">
  <section class="section">
    <h1>Writing</h1>
    <p class="muted">Notes on what I'm building and learning.</p>

    {posts.length === 0 ? (
      <p style="margin-top:20px;">No posts yet — check back soon.</p>
    ) : (
      <ul class="post-list" style="margin-top:24px;">
        {posts.map((post) => (
          <li>
            <div class="date">{fmt(post.data.pubDate)}</div>
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
            {post.data.description && <p>{post.data.description}</p>}
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
